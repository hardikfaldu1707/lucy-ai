# Copy to .env.local and fill in values. Never commit .env.local.
# See docs/17-environment-variables.md for details.

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clerk (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenRouter (https://openrouter.ai)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=moonshotai/kimi-k2.6:free

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# Upstash Redis (required in production)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Stripe (optional in dev when BILLING_DEV_BYPASS is on)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PREMIUM=
STRIPE_PRICE_ULTIMATE=

# Optional
TENANT_SLUG=lucy
BILLING_DEV_BYPASS=true
OPENAI_API_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
